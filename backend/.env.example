# Supabase (create project at supabase.com)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=YOUR_SUPABASE_ANON_KEY

# Database (Supabase Postgres — use "Transaction" mode connection string)
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres

# Redis (Upstash — copy REST URL from dashboard)
REDIS_URL=rediss://default:YOUR_TOKEN@YOUR_HOST:6379

# JWT (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=CHANGE_ME

# Dev overrides (optional)
DEBUG=True
