{
  "rewrites": [
    { "source": "/preco-perto/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/preco-perto/(.*)", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/preco-perto/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}